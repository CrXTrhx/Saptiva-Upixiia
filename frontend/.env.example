# Copia este archivo a .env.local:  cp .env.example .env.local
# URL del backend. Debe coincidir con el puerto del compose / uvicorn (4000).
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Datos del sistema que se muestran en las instrucciones al cliente.
# El correo debe coincidir con SYSTEM_EMAIL del backend y la Route de Mailgun.
NEXT_PUBLIC_SYSTEM_EMAIL=documentos@mg.digitalfoldr.com
NEXT_PUBLIC_SYSTEM_WHATSAPP=+52 55 0000 0000
