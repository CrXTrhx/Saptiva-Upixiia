# ---- Base de datos (Neon, PostgreSQL 16) ----
# Usa el connection string DIRECTO (sin -pooler). El backend lo normaliza a
# postgresql+psycopg://... automaticamente. NO subir el .env real al repo.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ---- Entorno ----
# development | production. En production se OCULTAN /docs, /redoc y /openapi.json.
ENVIRONMENT=development

# ---- Seguridad / Auth ----
# Usa un secreto LARGO y aleatorio en produccion (p.ej. `openssl rand -hex 32`).
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRE_MINUTES=480
# Usuario admin que se crea con `python -m app.seed`
ADMIN_EMAIL=admin@centur.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# ---- CORS (origen del frontend) ----
CORS_ORIGINS=http://localhost:3000

# ---- Datos del sistema (para instrucciones al cliente) ----
# SYSTEM_EMAIL es la direccion a la que el cliente envia sus documentos; debe
# coincidir con la Route de Mailgun (ver bloque Correo abajo).
SYSTEM_WHATSAPP=+52 55 0000 0000
SYSTEM_EMAIL=documentos@mg.digitalfoldr.com

# ---- Storage de archivos: Cloudflare R2 (S3-compatible) ----
# Si STORAGE_BACKEND=local se usa disco local (./storage_local) en dev.
# Con r2 el bucket queda PRIVADO: la lectura se hace con URLs firmadas temporales
# (presigned), apropiado para documentos de identidad. NO requiere hacer el bucket
# publico ni configurar R2_PUBLIC_BASE_URL.
STORAGE_BACKEND=local                      # local | r2
# Retencion (dias) de archivos temporales en R2 antes de que el cron los borre.
RETENCION_REEMPLAZOS_DIAS=7                 # versiones reemplazadas de 2+ niveles atras
RETENCION_OTHER_DIAS=7                      # documentos clasificados OTHER y rechazados (basura)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=                        # opcional, no se usa con presigned

# ---- Google Document AI (clasificacion + extraccion) ----
# 1 Custom Document Classifier (verifica el tipo) + 1 Custom Extractor por tipo.
# Crear los procesadores en la consola de Document AI y pegar aqui sus IDs.
GCP_PROJECT_ID=
DOCAI_LOCATION=us                          # us | eu
DOCAI_CLASSIFIER_ID=
DOCAI_EXTRACTOR_OFFICIAL_ID=               # INE
DOCAI_EXTRACTOR_CURP=
DOCAI_EXTRACTOR_TAX_STATUS=                # Constancia de Situacion Fiscal
DOCAI_EXTRACTOR_PROOF_ADDRESS=             # Comprobante de domicilio
# Ruta al JSON del service account (rol roles/documentai.apiUser). NO subir al repo.
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Integraciones externas (stub por ahora) ----
SINCH_API_TOKEN=
# Secretos compartidos para firmar los webhooks JSON demo (/webhooks/whatsapp y
# /webhooks/email). AHORA SON OBLIGATORIOS: si quedan vacios esos endpoints
# rechazan todo (fail-closed). El emisor debe mandar HMAC-SHA256(secreto, cuerpo)
# en la cabecera X-Sinch-Signature / X-Email-Signature. (El correo real de Mailgun
# usa su propia MAILGUN_SIGNING_KEY, mas abajo.)
SINCH_WEBHOOK_SECRET=
EMAIL_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
LLM_USE_REAL=false                         # false = stub basado en reglas de umbral
EXTRACTION_CONFIDENCE_THRESHOLD=70

# ---- Correo (Mailgun): envio de confirmaciones + recepcion de documentos ----
# MAILGUN_API_KEY: Private API key. MAILGUN_DOMAIN: el dominio verificado (subdominio).
# MAIL_FROM: remitente RESPONDIBLE. Debe ser la bandeja a la que el cliente envia
#   documentos (SYSTEM_EMAIL), NO un noreply, para que al responder el correo sus
#   archivos lleguen al webhook entrante. MAILGUN_BASE_URL: US por defecto, EU si aplica.
# MAILGUN_SIGNING_KEY: HTTP webhook signing key (valida correos entrantes); vacia = se omite.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.digitalfoldr.com
MAIL_FROM=Digital Foldr <documentos@mg.digitalfoldr.com>
MAILGUN_BASE_URL=https://api.mailgun.net
MAILGUN_SIGNING_KEY=
